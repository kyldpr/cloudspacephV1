RewriteEngine On

# ==========================================
# 0. PRESERVE HTTP AUTHORIZATION HEADER
# ==========================================
# Crucial for environments like InfinityFree that strip the Authorization header
RewriteCond %{HTTP:Authorization} .
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# ==========================================
# 1. PROTECT JSON PROFILES FROM WEB ACCESS
# ==========================================
RewriteRule ^api/profiles/users/.*$ - [F,L]

# ==========================================
# 2. REMOVE .PHP EXTENSION FROM URLS
# ==========================================
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^\.]+)$ $1.php [NC,L]

# ==========================================
# 3. REMOVE .HTML EXTENSION FROM URLS
# ==========================================
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^\.]+)$ $1.html [NC,L]