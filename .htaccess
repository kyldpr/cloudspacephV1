RewriteEngine On

# ==========================================
# 1. PROTECT JSON PROFILES FROM WEB ACCESS
# ==========================================
# This blocks any direct browser requests to files inside api/profiles/users/
RewriteRule ^api/profiles/users/.*$ - [F,L]


# ==========================================
# 2. REMOVE .PHP EXTENSION FROM URLS
# ==========================================
# If a user goes to /auth-api, internally rewrite it to /auth-api.php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^\.]+)$ $1.php [NC,L]


# ==========================================
# 3. REMOVE .HTML EXTENSION FROM URLS
# ==========================================
# If a user goes to /register, internally rewrite it to /register.html
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^\.]+)$ $1.html [NC,L]